<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="16dp"
    android:layout_marginEnd="16dp"
    android:layout_marginTop="10dp"
    android:layout_marginBottom="2dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="2dp"
    android:foreground="?attr/selectableItemBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- HÀNG 1: BADGE ƯU TIÊN + (tuỳ chọn) badge loại file -->
        <LinearLayout
            android:id="@+id/layoutBadges"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvPriorityBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:text="Thấp"
                android:textColor="#16A34A"
                android:textSize="12sp"
                android:textStyle="bold"
                android:background="@drawable/badge_priority_low"
                android:layout_marginEnd="6dp" />

            <TextView
                android:id="@+id/tvTaskNote"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:textSize="12sp"
                android:textColor="#6B7280"
                android:background="@drawable/badge_tag"
                android:visibility="gone" />

        </LinearLayout>

        <!-- HÀNG 2: TIÊU ĐỀ TASK -->
        <TextView
            android:id="@+id/tvTaskTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#111827"
            android:maxLines="2"
            android:ellipsize="end" />

        <!-- HÀNG 3.5: FILE ĐÍNH KÈM (chỉ hiện khi task có file) -->
        <LinearLayout
            android:id="@+id/layoutAttachedFile"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/badge_tag"
            android:padding="8dp"
            android:visibility="gone"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@android:drawable/ic_menu_save"
                app:tint="#2962FF" />

            <TextView
                android:id="@+id/tvAttachedFile"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:textColor="#2962FF"
                android:textSize="12sp"
                android:ellipsize="middle"
                android:singleLine="true" />

        </LinearLayout>

        <!-- HÀNG 3: NGÀY HẠN -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvTaskDueDate"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="📅 Chưa đặt hạn"
                android:textColor="#6B7280"
                android:textSize="13sp" />

            <!-- CheckBox đánh dấu hoàn thành -->
            <CheckBox
                android:id="@+id/cbTaskDone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:buttonTint="#2962FF" />

            <!-- Nút sửa/xóa ẩn (trigger từ long-press hoặc menu) -->
            <ImageButton
                android:id="@+id/btnEditTask"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_edit"
                android:contentDescription="Sửa"
                android:tint="#94A3B8" />

            <ImageButton
                android:id="@+id/btnDeleteTask"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_delete"
                android:contentDescription="Xóa"
                android:tint="#EF4444" />

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>
